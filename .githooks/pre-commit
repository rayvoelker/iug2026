#!/usr/bin/env bash
# Pre-commit hook: block secrets and sensitive data from being committed

RED='\033[0;31m'
NC='\033[0m'

# Patterns that should never be committed
PATTERNS=(
  'github_pat_'
  'ghp_'
  'GITHUB_TOKEN='
  'sk-[a-zA-Z0-9]'
  'ANTHROPIC_API_KEY'
  'password\s*='
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND=0

for pattern in "${PATTERNS[@]}"; do
  MATCHES=$(echo "$STAGED_FILES" | grep -v '.githooks/' | xargs grep -lnE "$pattern" 2>/dev/null)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}BLOCKED:${NC} Found secret pattern '${pattern}' in:"
    echo "$MATCHES" | while read -r file; do
      grep -nE "$pattern" "$file" | head -3 | sed "s/^/  $file:/"
    done
    FOUND=1
  fi
done

# Block .env files explicitly
for file in $STAGED_FILES; do
  if [[ "$file" == ".env" || "$file" == *.env || "$file" == .env.* ]]; then
    echo -e "${RED}BLOCKED:${NC} .env file staged: $file"
    FOUND=1
  fi
done

if [ $FOUND -ne 0 ]; then
  echo ""
  echo "Commit aborted. Remove secrets before committing."
  exit 1
fi

exit 0
