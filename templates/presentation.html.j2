<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">

		<meta name="description" content="{{ meta.description }}">
		<meta name="keywords" content="{{ meta.keywords }}">
		<meta name="author" content="{{ meta.author }}">

		<title>{{ meta.title }} - IUG 2026 - {{ meta.author }}</title>

		<link rel="stylesheet" href="node_modules/reveal.js/dist/reset.css">
		<link rel="stylesheet" href="node_modules/reveal.js/dist/reveal.css">
		<link rel="stylesheet" href="node_modules/reveal.js/dist/theme/white.css" id="theme">
		<link rel="stylesheet" href="css/iug2026.css">

		<!-- Syntax highlighting -->
		<link rel="stylesheet" href="node_modules/reveal.js/dist/plugin/highlight/monokai.css" id="highlight-theme">
	</head>
	<body>
		<!-- Logo panel for title/closing slides — OUTSIDE .reveal so CSS transforms don't affect it -->
		<div class="title-logo-panel" style="display: none;">
			<img src="assets/iug2026-logo.jpg" alt="IUG 2026 Chicago">
		</div>

		<div class="reveal">
			<!-- Persistent footer bar matching template (beige bar + logo) -->
			<div class="footer-bar">
				<img src="assets/iug2026-logo.jpg" alt="IUG 2026 Chicago">
			</div>

			<div class="slides">
{% for slide in slides %}
{% if slide.type == 'title' %}
				<!-- TITLE SLIDE -->
				<section class="title-slide" data-background-color="#F3E4C5" data-state="no-footer">
					<div class="title-content">
						<h1{% if slide.title_style %} style="{{ slide.title_style }}"{% endif %}>{{ slide.title }}</h1>
						<h2>{{ slide.subtitle }}</h2>
						<p>
							{{ meta.author }}<br>
							{{ meta.institution }}<br>
							<a href="mailto:{{ meta.email }}">{{ meta.email }}</a>
						</p>
					</div>
				</section>

{% elif slide.type == 'closing' %}
				<!-- CLOSING SLIDE -->
				<section class="title-slide" data-background-color="#F3E4C5" data-state="no-footer">
					<div class="title-content">
						<h1 style="font-size: 1.4em;">{{ slide.title }}</h1>
						<p style="font-size: 0.65em; margin-bottom: 1em;">
							{{ slide.body }}
						</p>
						<p>
							{{ meta.author }}<br>
							<a href="mailto:ray.voelker@gmail.com">ray.voelker@gmail.com</a> |
							<a href="mailto:{{ meta.email }}">{{ meta.email }}</a><br>
							<a href="https://github.com/rayvoelker">github.com/rayvoelker</a>
						</p>
					</div>
				</section>

{% elif slide.type == 'content' %}
				<section{% if slide.background %} data-background-color="{{ slide.background }}"{% endif %}>
{% if slide.custom_html %}
					{{ slide.custom_html }}
{% else %}
{% if slide.title %}
					<h2>{{ slide.title }}</h2>
{% endif %}
{% if slide.subtitle %}
					<p style="font-size: 0.7em;">{{ slide.subtitle }}</p>
{% endif %}
{% if slide.bullets %}
					<ul>
{% for bullet in slide.bullets %}
						<li>{{ bullet }}</li>
{% endfor %}
{% if slide.sub_bullets %}
						<ul>
{% for sub in slide.sub_bullets %}
							<li>{{ sub }}</li>
{% endfor %}
						</ul>
{% endif %}
{% if slide.bullets_after %}
{% for bullet in slide.bullets_after %}
						<li>{{ bullet }}</li>
{% endfor %}
{% endif %}
					</ul>
{% endif %}
{% if slide.numbered %}
					<ol>
{% for item in slide.numbered %}
						<li><strong>{{ item.title }}</strong><br>
							<span style="font-size: 0.7em;">{{ item.detail }}</span></li>
{% endfor %}
					</ol>
{% endif %}
{% if slide.code %}
					<pre><code data-trim class="{{ slide.code.language }}">
{{ slide.code.body }}					</code></pre>
{% endif %}
{% if slide.links_list %}
					<ul style="font-size: 0.7em;">
{% for link in slide.links_list %}
						<li><a href="{{ link.url }}">{{ link.text }}</a></li>
{% endfor %}
					</ul>
{% endif %}
{% if slide.link %}
					<p style="margin-top: 0.8em; font-size: 0.6em;">
						<a href="{{ slide.link.url }}" target="_blank">{{ slide.link.text }}</a>
					</p>
{% endif %}
{% if slide.footer_text %}
					<p style="font-size: 0.7em; margin-top: 1em;">
						{{ slide.footer_text }}
					</p>
{% endif %}
{% endif %}
{% if slide.notes %}
					<aside class="notes">
						{{ slide.notes }}
					</aside>
{% endif %}
				</section>

{% elif slide.type == 'iframe' %}
				<section data-background="white">
					<h2>{{ slide.title }}</h2>
					<iframe src="{{ slide.url }}"
						style="width: 100%; height: 550px; border: 2px solid #E8E8E8; border-radius: 8px;">
					</iframe>
{% if slide.notes %}
					<aside class="notes">
						{{ slide.notes }}
					</aside>
{% endif %}
				</section>

{% elif slide.type == 'columns' %}
				<section>
					<h2>{{ slide.title }}</h2>
					<div class="columns" style="font-size: 0.65em;">
						<div class="col">
							<h3>{{ slide.left.heading }}</h3>
{% if slide.left.code %}
							<pre><code data-trim class="{{ slide.left.code.language }}">
{{ slide.left.code.body }}							</code></pre>
{% endif %}
						</div>
						<div class="col">
							<h3>{{ slide.right.heading }}</h3>
{% if slide.right.code %}
							<pre><code data-trim class="{{ slide.right.code.language }}">
{{ slide.right.code.body }}							</code></pre>
{% endif %}
						</div>
					</div>
{% if slide.notes %}
					<aside class="notes">
						{{ slide.notes }}
					</aside>
{% endif %}
				</section>

{% elif slide.type == 'table' %}
				<section>
					<h2>{{ slide.title }}</h2>
					<table style="font-size: 0.55em;">
						<thead>
							<tr>
{% for header in slide.headers %}
								<th>{{ header }}</th>
{% endfor %}
							</tr>
						</thead>
						<tbody>
{% for row in slide.rows %}
							<tr>
{% for cell in row %}
								<td>{{ cell }}</td>
{% endfor %}
							</tr>
{% endfor %}
						</tbody>
					</table>
{% if slide.footer_text %}
					<p style="font-size: 0.6em; margin-top: 0.8em;">
						{{ slide.footer_text }}
					</p>
{% endif %}
{% if slide.notes %}
					<aside class="notes">
						{{ slide.notes }}
					</aside>
{% endif %}
				</section>

{% endif %}
{% endfor %}
			</div>
		</div>

		<script src="node_modules/reveal.js/dist/reveal.js"></script>
		<script src="node_modules/reveal.js/dist/plugin/notes.js"></script>
		<script src="node_modules/reveal.js/dist/plugin/markdown.js"></script>
		<script src="node_modules/reveal.js/dist/plugin/highlight.js"></script>
		<script>
			Reveal.initialize({
				hash: true,
				slideNumber: true,
				plugins: [ RevealMarkdown, RevealHighlight, RevealNotes ]
			});

			// Toggle footer bar and logo panel based on slide type
			function updateChrome(slide) {
				const footer = document.querySelector('.footer-bar');
				const logoPanel = document.querySelector('.title-logo-panel');
				const isTitle = slide.classList.contains('title-slide');
				const hasDarkBg = slide.dataset.backgroundColor === '#00223D' ||
				                  slide.dataset.backgroundColor === '#0E2841';
				footer.style.display = (isTitle || hasDarkBg) ? 'none' : 'flex';
				logoPanel.style.display = isTitle ? 'flex' : 'none';
			}
			Reveal.on('slidechanged', event => updateChrome(event.currentSlide));
			Reveal.on('ready', event => updateChrome(event.currentSlide));
		</script>
	</body>
</html>
